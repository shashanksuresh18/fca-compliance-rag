# ============================================================
# Environment Variables — Phase 2 Free Stack
# Copy to .env and fill in your keys
# ============================================================

# --- Groq API (FREE LLM) ---
# Sign up at https://console.groq.com — no credit card required
GROQ_API_KEY=gsk_...your-groq-key-here...

# --- LLM Model ---
LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings (LOCAL — no API key required) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Retrieval ---
TOP_K=5

# === PHASE 2 SETTINGS ===

# Hybrid retrieval: BM25 keyword + vector search (recommended: true)
# Set to false to fall back to Phase 1 vector-only behaviour
USE_HYBRID=true

# Cross-encoder re-ranking: higher quality, adds ~200ms latency
# Set to false for faster responses (uses RRF order instead)
USE_RERANKER=true

# Cross-encoder model (22MB, downloaded once, runs on CPU)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# How many candidates to fetch before fusion + re-ranking
# e.g. TOP_K=5, CANDIDATE_K_MULTIPLIER=2 → fetch 10 from each method
CANDIDATE_K_MULTIPLIER=2

# Prompt version: v2 = chain-of-thought (recommended), v1 = basic
PROMPT_VERSION=v2

# --- API Security ---
API_SECRET_KEY=change-me-in-production
