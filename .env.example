# ============================================================
# Environment Variables — FREE STACK
# Copy this file to .env and fill in your free API keys
# ============================================================

# --- Groq API (FREE LLM) ---
# Sign up at https://console.groq.com — no credit card required
# You get 14,400 free requests/day with llama-3.3-70b
GROQ_API_KEY=gsk_...your-groq-key-here...

# --- LLM Model ---
# FREE options on Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings (LOCAL — no API key required) ---
# Model is downloaded once (~90MB) and cached locally
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Retrieval ---
TOP_K=5

# --- API Security ---
API_SECRET_KEY=change-me-in-production
